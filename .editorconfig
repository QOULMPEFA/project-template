# EditorConfig: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{py,js,ts,jsx,tsx,java,go,rs,c,cpp,h,hpp,cs,rb,php,swift,kt}]
indent_size = 4

[*.{yml,yaml,json,md,css,scss,html,xml,svg,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
